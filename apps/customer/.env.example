# 백엔드 API root URL (api-client-convention §2·§3). /api/v1 은 axios 가 붙이므로 도메인까지만.
# 로컬 BE: http://localhost:8080 · 운영: https://api.magampick.com
VITE_API_BASE_URL=http://localhost:8080

# 카카오 로그인 REST API 키 (소셜 로그인 인가 리다이렉트 — 소비자 전용, auth.md §6·§15)
# 발급: https://developers.kakao.com → 내 애플리케이션 → 앱 키 → "REST API 키"
# 카카오 로그인 ON + Redirect URI 에 {origin}/login/kakao/callback 등록 (예: http://localhost:5173/login/kakao/callback)
# 비워두면 로컬 dev 우회 — 키 없이 콜백에 더미 code 를 넘겨 BE local mock 흐름을 테스트한다.
VITE_KAKAO_CLIENT_ID=

# 카카오맵 JavaScript 키 (지도 기반 매장 조회 — 소비자 `/map`)
# 발급: https://developers.kakao.com → 내 애플리케이션 → 앱 키 → "JavaScript 키"
# 플랫폼 > Web 사이트 도메인에 개발 포트 등록 필요 (예: http://localhost:5173, http://localhost:15173)
# ⚠️ REST API 키(서버 지오코딩용 KAKAO_REST_API_KEY)와 다른 키다.
VITE_KAKAO_MAP_KEY=

# FCM (웹 푸시) — Firebase 콘솔 > 프로젝트 설정 > 웹 앱 config 5개 + 클라우드 메시징 > 웹 푸시 인증서(VAPID).
# 값은 공개(클라이언트 노출 정상). 미설정 시 FCM 비활성(앱은 정상 동작).
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_VAPID_KEY=

# 토스페이먼츠 결제 (API 개별 연동, VITE_USE_REAL_PAYMENT=true 시 활성화)
# 발급: https://developers.tosspayments.com → 내 개발정보 → API 키 → "클라이언트 키"
#   - 테스트 키: test_ck_* (결제위젯 키 test_gck_* 와 호환 안 됨)
#   - 운영 키: live_ck_* (서버 시크릿 키 sk_* 는 절대 프론트에 넣지 말 것)
VITE_TOSS_CLIENT_KEY=

# 실 결제 흐름 활성화 플래그 ('true' 면 prepare→토스 결제창→confirm 경로, 비워두면 stub 경로)
# ⚠️ 상품/매장/카트 실연동 완료 후에만 'true' 로 설정할 것 (상류 mock 상태에선 storeId·refId 가 NaN)
VITE_USE_REAL_PAYMENT=
