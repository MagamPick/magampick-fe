# 백엔드 API root URL (api-client-convention §2·§3). /api/v1 은 axios 가 붙이므로 도메인까지만.
# 로컬 BE: http://localhost:8080 · 운영: https://api.magampick.com
VITE_API_BASE_URL=http://localhost:8080

# FCM (웹 푸시) — Firebase 콘솔 > 프로젝트 설정 > 웹 앱 config 5개 + 클라우드 메시징 > 웹 푸시 인증서(VAPID).
# 값은 공개(클라이언트 노출 정상). 미설정 시 FCM 비활성(앱은 정상 동작).
# 소비자와 같은 프로젝트의 사장 전용 web app — VITE_FIREBASE_APP_ID 만 사장 web app 값,
# 나머지 5개는 프로젝트 공통(소비자와 동일). public/firebase-messaging-sw.js 의 appId 와 일치시킬 것.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_VAPID_KEY=
